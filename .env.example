# Copiez ce fichier en ".env" et ajustez les valeurs.
# (Le fichier .env n'est jamais partage ni mis sur GitHub : il contient vos secrets.)

# Port du serveur web (3000 par defaut)
PORT=3000

# Secret pour securiser les sessions de connexion.
# Mettez une longue suite de caracteres aleatoires en production.
SESSION_SECRET=changez-ce-secret-par-une-longue-chaine-aleatoire

# Identifiants du PREMIER compte admin (cree au tout premier demarrage).
# Apres le premier lancement, le mot de passe est stocke hache dans la base ;
# changer ces valeurs ici ne change pas un compte deja cree.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ybmtl2026

# Coordonnees affichees dans le pied de page du site
COMPANY_PHONE=(514) 000-0000
COMPANY_EMAIL=info@locationybmtl.ca
