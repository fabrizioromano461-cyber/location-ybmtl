  </main>
  <footer class="site-footer" id="contact">
    <div class="container footer-inner">
      <div class="footer-brand">
        <img src="/img/logo-rogne.png" alt="Location YBMTL" class="footer-logo">
        <p>Location de véhicules à <%= company.city %>.</p>
      </div>
      <div class="footer-contact">
        <h4>Nous joindre</h4>
        <p>Téléphone : <a href="tel:<%= company.phone.replace(/[^0-9+]/g,'') %>"><%= company.phone %></a></p>
        <p>Courriel : <a href="mailto:<%= company.email %>"><%= company.email %></a></p>
        <p class="footer-note">Les réservations sont confirmées manuellement par téléphone ou courriel. Aucun paiement en ligne.</p>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="container">
        <div class="footer-bottom-inner">
          <span>&copy; <%= new Date().getFullYear() %> <%= company.name %>. Tous droits réservés.</span>
          <a href="/conditions" class="footer-link">Conditions & Contrat</a>
        </div>
      </div>
    </div>
  </footer>
</body>
</html>
